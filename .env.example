# ==============================================================================
# MORENO CAR CENTER - CONFIGURACIÓN DE ENTORNO (.env.example)
# ==============================================================================
# Copia este archivo a .env y completa con tus credenciales de Google Cloud,
# Firebase, Resend y Google Tag Manager. El archivo .env está protegido por .agentignore.

# ------------------------------------------------------------------------------
# 1. GOOGLE CLOUD & FIREBASE (Autenticación, Firestore, Storage & Hosting)
# ------------------------------------------------------------------------------
VITE_FIREBASE_API_KEY="AIzaSyYourFirebaseApiKeyHere"
VITE_FIREBASE_AUTH_DOMAIN="moreno-car-center.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="moreno-car-center"
VITE_FIREBASE_STORAGE_BUCKET="moreno-car-center.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789012"
VITE_FIREBASE_APP_ID="1:123456789012:web:abcdef1234567890"

# ------------------------------------------------------------------------------
# 2. ANALÍTICA LIMPIA (Google Tag Manager)
# ------------------------------------------------------------------------------
VITE_GTM_ID="GTM-XXXXXXX"

# ------------------------------------------------------------------------------
# 3. COMUNICACIONES & MARKETING (Resend API)
# ------------------------------------------------------------------------------
VITE_RESEND_API_KEY="re_123456789_YourResendApiKeyHere"
VITE_RESEND_FROM_EMAIL="turnos@morenocarcenter.com"

# ------------------------------------------------------------------------------
# 4. ASISTENTE VIRTUAL DE TURNOS CON INTELIGENCIA ARTIFICIAL (Gemini AI)
# ------------------------------------------------------------------------------
VITE_GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"

# ------------------------------------------------------------------------------
# 5. GOOGLE STITCH MCP (Integración y sincronización de Diseño Premium)
# ------------------------------------------------------------------------------
STITCH_PROJECT_ID="stitch_project_id_placeholder"
